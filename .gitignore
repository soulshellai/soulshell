# Masuk ke folder
cd ~/Downloads/soulshell-github
# (ganti "Downloads" sesuai lokasi extract kamu)

# Init git & add semua file (termasuk hidden)
git init
git add .
git commit -m "initial commit"

# Set branch & push ke GitHub
git branch -M main
git remote add origin https://github.com/soulshellai/soulshell.git
git push -u origin main
